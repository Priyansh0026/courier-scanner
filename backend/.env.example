# Server Port Configuration
PORT=5000

# Client Application URL (For CORS setup)
CLIENT_URL=http://localhost:5173

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/jcms_secure_auth

# JWT Secrets and Expirations
JWT_ACCESS_SECRET=your_jwt_access_secret_key_change_me_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Twilio SMS API Credentials (Choose either Twilio Verify OR MSG91)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# MSG91 SMS API Credentials (Alternative to Twilio, popular in India)
# MSG91_AUTH_KEY=your_msg91_auth_key_here
# MSG91_DLT_TEMPLATE_ID=your_dlt_template_id_here

# Nodemailer SMTP Email Credentials (Gmail SMTP example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password_here
EMAIL_FROM="JCMS Suite" <your_gmail_address@gmail.com>

# Environment Mode
NODE_ENV=development
